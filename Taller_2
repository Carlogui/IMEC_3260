    {
      "cell_type": "code",
      "source": [
        "# Datos\n",
        "L_443 = 4.0            # m (longitud en la dirección del flujo)\n",
        "b_443 = 4.0            # m (ancho)\n",
        "Re_tr_443 = 5e5        # transición\n",
        "rho_443 = 1.225        # kg/m^3\n",
        "nu_443  = 1.460e-5     # m^2/s\n",
        "\n",
        "# Áreas\n",
        "A_1side_443 = L_443 * b_443\n",
        "A_2sides_443 = 2.0 * A_1side_443   # placa delgada: flujo por ambas caras (si tu profe asume 1 cara, usa A_1side_443)\n",
        "\n",
        "def Cf_avg_transitional_443(Re_L):\n",
        "    # Placa plana con transición a Re_x = 5e5 :\n",
        "    return 0.074/(Re_L**0.2) - 1742.0/Re_L\n",
        "\n",
        "def friction_drag_443(V, A_wet):\n",
        "    Re_L = V * L_443 / nu_443\n",
        "    Cf_bar = Cf_avg_transitional_443(Re_L)\n",
        "    q = 0.5 * rho_443 * V**2\n",
        "    Df = q * A_wet * Cf_bar\n",
        "    return Re_L, Cf_bar, Df\n",
        "\n",
        "V1_443 = 20.0  # m/s\n",
        "V2_443 = 40.0  # m/s\n",
        "\n",
        "Re1_443, Cf1_443, D1_443 = friction_drag_443(V1_443, A_2sides_443)\n",
        "Re2_443, Cf2_443, D2_443 = friction_drag_443(V2_443, A_2sides_443)\n",
        "\n",
        "n_443 = math.log(D2_443/D1_443) / math.log(V2_443/V1_443)\n",
        "\n",
        "display(Markdown(\n",
        "f\"\"\"\n",
        "### Problema 4.43 — Resultados (placa con **2 caras** mojadas)\n",
